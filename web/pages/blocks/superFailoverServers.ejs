<div class="tab-pane text-left" id="failoverServers" role="tabpanel">
    <form>
        <div class="row" style="display:flex">
            <div class="col-md-12">
                <% if(!config.userHasSubscribed){ %>
                    <div class="card bg-dark text-white mb-4">
                        <div class="card-header">
                            <%- lang['Failover Servers'] %>
                        </div>
                        <div class="card-body">
                            <div class="text-center"><%- lang.failoverServersNotEnabled %></div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="card bg-dark text-white mb-4">
                        <div class="card-header">
                            <%- lang['Failover Servers'] %>
                        </div>
                        <div class="card-body">
                            <div class="text-center mb-3"><%- lang.failoverServersDescription %></div>
                            <div class="form-group">
                                <input placeholder="<%-lang['Server URL']%>" class="form-control btn btn-dark text-left text-white" type="text" name="failoverServer" value="" placeholder="ws://127.0.0.1:8663">
                            </div>
                            <div class="form-group">
                                <input placeholder="<%-lang['Server Key']%>" class="form-control btn btn-dark text-left text-white" type="text" name="peerConnectKey" value="" placeholder="API Key from https://licenses.shinobi.video">
                            </div>
                            <div class="btn-group d-flex flex-row">
                                <a href="#" class="submit flex-grow-1 btn btn-success"><i class="fa fa-check"></i> <%- lang.Save %></a>
                            </div>
                        </div>
                    </div>
                    <div class="card bg-dark text-white">
                        <div class="card-body">
                            <table class="table table-striped">
                                <tbody id="failoverServers-list"></tbody>
                            </table>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </form>
    <script src="<%-window.libURL%>assets/js/super.failoverServers.isNormal.js" type="text/javascript"></script>
</div>
